# Doxygen configuration for fyp-sfml-game

PROJECT_NAME           = "Project Rival"
PROJECT_NUMBER         = "main"
OUTPUT_DIRECTORY       = docs/doxygen

# What to scan
INPUT                  = project-rival
FILE_PATTERNS          = *.h *.hpp *.cpp *.cxx
RECURSIVE              = YES

# Extract docs
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO

# Output formats
GENERATE_HTML          = YES
GENERATE_LATEX         = NO

# Diagrams (Graphviz)
HAVE_DOT               = YES
DOT_GRAPH_MAX_NODES    = 100
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
UML_LOOK               = YES

# Quality-of-life
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO

# Prefer C++ parsing
OPTIMIZE_OUTPUT_FOR_C  = NO